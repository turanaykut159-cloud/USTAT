# ÜSTAT .gitattributes — v3.0 Operational Constitution
# Amac: CRLF/LF kaosunu kokten cozmek. Her platform ayni satir sonunu gorur.
# Bu dosya olmadigi icin 17 modified dosya gurultusu yasandi (2026-04-14 oturumu).

# Varsayilan: metin dosyalari LF normalize
* text=auto eol=lf

# Windows native scriptleri CRLF kalsin (yoksa PowerShell bozulur)
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.vbs       text eol=crlf

# Kod dosyalari kesin LF
*.py        text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.sh        text eol=lf
*.html      text eol=lf
*.css       text eol=lf

# Binary — diff/merge yok
*.db        binary
*.sqlite    binary
*.sqlite3   binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.xlsx      binary
*.docx      binary
*.pptx      binary
